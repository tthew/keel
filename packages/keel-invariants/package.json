{
  "name": "@keel/keel-invariants",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tsconfig": "./tsconfig.base.json",
    "./eslint": "./eslint.config.keel-invariants.js",
    "./prettier": "./prettier.config.keel-invariants.js",
    "./commitlint": "./commitlint.config.keel-invariants.js",
    "./eslint-plugin": "./src/eslint-rules/index.js"
  },
  "bin": {
    "keel-invariants-check": "./dist/check.js",
    "keel-invariants:tokens-schema": "./dist/check-tokens-schema.js",
    "keel-invariants:tokens-contrast": "./dist/check-tokens-contrast.js",
    "keel-invariants:no-committed-dotfiles": "./dist/check-no-committed-dotfiles.js",
    "keel-invariants:claude-hook-syntax": "./dist/check-claude-hook-syntax.js",
    "keel-invariants:nfr5a-minimum": "./dist/check-nfr5a-minimum.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "node dist/check.js",
    "keel-invariants:tokens-schema": "node dist/check-tokens-schema.js",
    "keel-invariants:tokens-contrast": "node dist/check-tokens-contrast.js",
    "keel-invariants:no-committed-dotfiles": "node dist/check-no-committed-dotfiles.js",
    "keel-invariants:claude-hook-syntax": "node dist/check-claude-hook-syntax.js",
    "keel-invariants:nfr5a-minimum": "node dist/check-nfr5a-minimum.js"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.0",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "typescript-eslint": "8.58.2",
    "vitest": "3.2.4"
  }
}
