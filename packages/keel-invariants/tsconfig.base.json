{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@keel/db": ["../db/src/index.ts"],
      "@keel/contracts": ["../contracts/src/index.ts"],
      "@keel/config": ["../config/src/index.ts"],
      "@keel/core": ["../core/src/index.ts"],
      "@keel/billing": ["../billing/src/index.ts"],
      "@keel/email": ["../email/src/index.ts"],
      "@keel/jobs": ["../jobs/src/index.ts"],
      "@keel/flags": ["../flags/src/index.ts"],
      "@keel/audit": ["../audit/src/index.ts"],
      "@keel/ui": ["../ui/src/index.ts"],
      "@keel/keel-invariants": ["../keel-invariants/src/index.ts"],
      "@keel/devbox": ["../devbox/src/index.ts"],
      "@keel/keel-generator": ["../keel-generator/src/index.ts"],
      "@keel/keel-templates": ["../keel-templates/src/index.ts"],
      "@keel/web": ["../../apps/web/src/index.ts"]
    }
  }
}
