{
  "color": {
    "neutral": {
      "50": { "$type": "color", "$value": "oklch(99% 0 0)" },
      "100": { "$type": "color", "$value": "oklch(96% 0 0)" },
      "200": { "$type": "color", "$value": "oklch(90% 0 0)" },
      "300": { "$type": "color", "$value": "oklch(80% 0 0)" },
      "400": { "$type": "color", "$value": "oklch(65% 0 0)" },
      "500": { "$type": "color", "$value": "oklch(52% 0 0)" },
      "600": { "$type": "color", "$value": "oklch(42% 0 0)" },
      "700": { "$type": "color", "$value": "oklch(30% 0 0)" },
      "800": { "$type": "color", "$value": "oklch(20% 0 0)" },
      "900": { "$type": "color", "$value": "oklch(13% 0 0)" },
      "950": { "$type": "color", "$value": "oklch(8% 0 0)" }
    },
    "accent": {
      "400": {
        "$type": "color",
        "$value": "oklch(62% 0.16 245)",
        "$description": "Direction A accent primitive — lighter; focus-ring surface (ux-design-specification.md:613 Direction A + ux-design-directions.html Direction A block)."
      },
      "500": {
        "$type": "color",
        "$value": "oklch(54% 0.18 245)",
        "$description": "Direction A accent primitive — ratified substrate default (ux-design-specification.md:613 Direction A; precedence over foundation:492 per Story 1.11 AC 1 scope carve-out)."
      },
      "600": {
        "$type": "color",
        "$value": "oklch(46% 0.18 245)",
        "$description": "Direction A accent primitive — darker; hover / pressed surface."
      },
      "default": { "$type": "color", "$value": "{color.accent.500}" },
      "fg": {
        "$type": "color",
        "$value": "oklch(99% 0 0)",
        "$description": "White-on-accent foreground (AA-tested against accent.500 in light mode; retained in dark mode via $modes.dark remap for AA against accent.500)."
      },
      "focus": { "$type": "color", "$value": "{color.accent.400}" }
    },
    "surface": {
      "default": { "$type": "color", "$value": "{color.neutral.50}" },
      "raised": { "$type": "color", "$value": "{color.neutral.100}" },
      "inset": { "$type": "color", "$value": "{color.neutral.100}" },
      "overlay": { "$type": "color", "$value": "{color.neutral.50}" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "{color.neutral.950}" },
      "secondary": { "$type": "color", "$value": "{color.neutral.700}" },
      "muted": { "$type": "color", "$value": "{color.neutral.500}" },
      "inverse": { "$type": "color", "$value": "{color.neutral.50}" },
      "accent": { "$type": "color", "$value": "{color.accent.default}" }
    },
    "border": {
      "default": { "$type": "color", "$value": "{color.neutral.200}" },
      "muted": { "$type": "color", "$value": "{color.neutral.100}" },
      "accent": { "$type": "color", "$value": "{color.accent.focus}" }
    },
    "status": {
      "info": {
        "fg": { "$type": "color", "$value": "oklch(52% 0.14 230)" },
        "bg": { "$type": "color", "$value": "oklch(95% 0.03 230)" }
      },
      "success": {
        "fg": { "$type": "color", "$value": "oklch(50% 0.15 145)" },
        "bg": { "$type": "color", "$value": "oklch(94% 0.04 145)" }
      },
      "warning": {
        "fg": { "$type": "color", "$value": "oklch(58% 0.14 75)" },
        "bg": { "$type": "color", "$value": "oklch(95% 0.06 75)" }
      },
      "error": {
        "fg": { "$type": "color", "$value": "oklch(52% 0.18 25)" },
        "bg": { "$type": "color", "$value": "oklch(94% 0.04 25)" }
      },
      "critical": {
        "fg": { "$type": "color", "$value": "oklch(45% 0.20 15)" },
        "bg": { "$type": "color", "$value": "oklch(92% 0.05 15)" }
      }
    },
    "severity": {
      "low": { "$type": "color", "$value": "{color.status.info.fg}" },
      "medium": { "$type": "color", "$value": "{color.status.warning.fg}" },
      "high": { "$type": "color", "$value": "{color.status.error.fg}" },
      "critical": { "$type": "color", "$value": "{color.status.critical.fg}" }
    },
    "state": {
      "pending": { "$type": "color", "$value": "{color.status.info.fg}" },
      "in-progress": { "$type": "color", "$value": "{color.accent.default}" },
      "blocked": { "$type": "color", "$value": "{color.status.warning.fg}" },
      "done": { "$type": "color", "$value": "{color.status.success.fg}" }
    }
  },
  "type": {
    "xs": { "$type": "dimension", "$value": "12px" },
    "sm": { "$type": "dimension", "$value": "14px" },
    "base": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "18px" },
    "xl": { "$type": "dimension", "$value": "20px" },
    "2xl": { "$type": "dimension", "$value": "24px" },
    "3xl": { "$type": "dimension", "$value": "30px" },
    "4xl": { "$type": "dimension", "$value": "36px" }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": "Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif"
    },
    "mono": {
      "$type": "fontFamily",
      "$value": "'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, Consolas, monospace"
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0px" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "motion": {
    "scale": {
      "$type": "number",
      "$value": "1",
      "$description": "Global motion dial (default 1; 0 = reduced-motion at runtime via OS preference, clamped in Story 1.12 emitter)."
    },
    "instant": { "$type": "duration", "$value": "60ms" },
    "snap": { "$type": "duration", "$value": "120ms" },
    "swift": { "$type": "duration", "$value": "200ms" },
    "smooth": { "$type": "duration", "$value": "320ms" },
    "drift": { "$type": "duration", "$value": "500ms" }
  },
  "density": {
    "scale": {
      "$type": "number",
      "$value": "1",
      "$description": "Global density dial (default 1; runtime-switchable per user preference or viewport class)."
    },
    "compact": { "$type": "number", "$value": "0.875" },
    "default": { "$type": "number", "$value": "1" },
    "comfortable": { "$type": "number", "$value": "1.125" }
  },
  "breakpoint": {
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl": { "$type": "dimension", "$value": "1536px" }
  },
  "$modes": {
    "light": {},
    "dark": {
      "color": {
        "surface": {
          "default": { "$type": "color", "$value": "{color.neutral.950}" },
          "raised": { "$type": "color", "$value": "{color.neutral.900}" },
          "inset": { "$type": "color", "$value": "{color.neutral.900}" },
          "overlay": { "$type": "color", "$value": "{color.neutral.900}" }
        },
        "text": {
          "primary": { "$type": "color", "$value": "{color.neutral.50}" },
          "secondary": { "$type": "color", "$value": "{color.neutral.200}" },
          "muted": { "$type": "color", "$value": "{color.neutral.400}" },
          "inverse": { "$type": "color", "$value": "{color.neutral.950}" }
        },
        "border": {
          "default": { "$type": "color", "$value": "{color.neutral.800}" },
          "muted": { "$type": "color", "$value": "{color.neutral.900}" }
        },
        "accent": {
          "fg": { "$type": "color", "$value": "{color.neutral.50}" }
        },
        "status": {
          "info": {
            "bg": { "$type": "color", "$value": "oklch(22% 0.05 230)" }
          },
          "success": {
            "bg": { "$type": "color", "$value": "oklch(22% 0.06 145)" }
          },
          "warning": {
            "bg": { "$type": "color", "$value": "oklch(24% 0.08 75)" }
          },
          "error": {
            "bg": { "$type": "color", "$value": "oklch(24% 0.07 25)" }
          },
          "critical": {
            "bg": { "$type": "color", "$value": "oklch(20% 0.08 15)" }
          }
        }
      }
    }
  }
}
